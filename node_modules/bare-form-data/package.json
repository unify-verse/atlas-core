  "dependencies": {
    "bare-buffer": "^3.6.0",
    "bare-stream": "^2.6.5"
  },
  "devDependencies": {
    "brittle": "^3.3.0",
    "lunte": "^1.7.0",
    "prettier": "^3.3.3",
    "prettier-config-holepunch": "^2.0.0"
  }
