{
  "name": "bare-thread",
  "version": "1.2.2",
  "description": "Thread support for Bare",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "binding.c",
    "binding.js",
    "CMakeLists.txt",
    "lib",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test": "brittle-bare --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/bare-thread.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/bare-thread/issues"
  },
  "homepage": "https://github.com/holepunchto/bare-thread#readme",
  "dependencies": {
    "bare-bundle": "^1.9.0",
    "bare-module-resolve": "^1.11.2",
    "bare-module-traverse": "^2.0.0",
    "bare-url": "^2.4.2"
  },
  "devDependencies": {
    "brittle": "^3.3.2",
    "cmake-bare": "^1.7.6",
    "lunte": "^1.6.0",
    "prettier": "^3.4.2",
    "prettier-config-holepunch": "^2.0.0"
  }
}
